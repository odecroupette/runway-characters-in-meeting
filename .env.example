# Public URL — how Recall's bot reaches this server
# For local dev: use ngrok (ngrok http 3000) or cloudflared
# For Railway: leave unset, auto-detected from RAILWAY_PUBLIC_DOMAIN
# For Fly.io: leave unset, auto-detected from FLY_APP_NAME
PUBLIC_URL=https://your-subdomain.ngrok-free.app

PORT=3000

# Server-side auth — password to unlock server-stored API keys from the browser
SERVER_PASSWORD=

# Server-side API keys (used when browser unlocks with SERVER_PASSWORD)
# Users can also enter their own keys locally in the browser instead.
SERVER_RUNWAY_KEY=
SERVER_RUNWAY_BASE_URL=https://api.dev.runwayml.com
SERVER_RECALL_KEY=
SERVER_RECALL_REGION=us-west-2
SERVER_DAILY_KEY=
SERVER_DAILY_DOMAIN=
